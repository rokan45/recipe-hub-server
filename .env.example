# ===== SERVER =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===== MONGODB =====
MONGODB_URI=your_mongodb_atlas_connection_string

# ===== JWT (custom token, separate from Better Auth session) =====
JWT_SECRET=your_long_random_jwt_secret_string
JWT_EXPIRES_IN=7d

# ===== BETTER AUTH =====
BETTER_AUTH_SECRET=your_long_random_better_auth_secret
BETTER_AUTH_URL=http://localhost:5000

# ===== GOOGLE OAUTH (for Better Auth Google login) =====
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===== STRIPE =====
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ===== ADMIN SEED (used by seed script only) =====
ADMIN_EMAIL=admin@recipehub.com
ADMIN_PASSWORD=ChangeThisPassword123
ADMIN_NAME=RecipeHub Admin
